# Continuity Bridge .gitignore
# PRIVATE REPO VERSION - Tracks everything for internal continuity

# ============================================================================
# SENSITIVE FILES - Never commit these (even to private repo)
# ============================================================================

# API keys, secrets, tokens
.env
.env.local
*.key
*.pem
secrets.json
config.json
api-keys.txt
COMMIT_MSG*

# System files
.DS_Store
Thumbs.db
desktop.ini

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.code-workspace

# Syncthing version history
.stversions/*
.stfolder/
.stignore
*.sync-conflict-*

# ============================================================================
# EVERYTHING ELSE IS TRACKED IN PRIVATE REPO
# ============================================================================
# We want to track:
# - Session logs
# - Instance journals
# - Active projects
# - Personal archives
# - All memory artifacts

# ============================================================================